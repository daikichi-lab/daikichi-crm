# 大吉CRM 環境変数（コピーして .env.local に。秘密はコミットしない＝SEC-5）

# ===== データドライバ =====
# pglite: 埋め込みPostgres（dev/test・Docker不要）/ supabase: 本番
APP_DATA_DRIVER=pglite
# 認証: dev（メールのみ・ローカル専用）/ supabase（本番）。未指定かつ本番(NODE_ENV=production)は supabase に既定（fail closed）。
APP_AUTH=dev
# dev でデモseedを投入する場合 1
APP_SEED=1
# セッションcookie署名鍵。**本番は必須**（長いランダム値）。未設定だと本番でセッション検証が常に失敗する。
APP_SESSION_SECRET=change-me-please-use-a-long-random-string

# ===== 本番 Supabase（APP_DATA_DRIVER=supabase / APP_AUTH=supabase のとき） =====
# リージョンは Tokyo 固定（C-7・国内保管）
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# service_role / sb_secret_* は**サーバー側のみ**。ブラウザ・NEXT_PUBLIC_* に絶対入れない（SEC-3）。
SUPABASE_SERVICE_ROLE_KEY=
